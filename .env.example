# JWT secret — change this to a long random string in production
JWT_SECRET=studentlife_jwt_secret_2026

# Admin credentials
ADMIN_EMAIL=host@shahriar.com
ADMIN_PASSWORD=2803
ADMIN_CODE=host2026

# Demo account credentials (auto-created on first demo login)
DEMO_EMAIL=demo@studentlifeos.app
